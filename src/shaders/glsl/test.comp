#version 450

#extension GL_GOOGLE_include_directive : require

layout(local_size_x = 16, local_size_y = 16) in;
layout(set = 1, binding = 0, rgba8) uniform writeonly image2D destImage;

struct HitInfo
{
    float dist;
    int material;
};

// ── Primitives ────────────────────────────────────────────────────────────────

float sdBox(vec3 p, vec3 b)
{
    vec3 q = abs(p) - b;
    return length(max(q, 0.0)) + min(max(q.x, max(q.y, q.z)), 0.0);
}

float sdCylinder(vec3 p, float r, float h)
{
    vec2 d = abs(vec2(length(p.xz), p.y)) - vec2(r, h);
    return min(max(d.x, d.y), 0.0) + length(max(d, 0.0));
}

// ── Repetition ────────────────────────────────────────────────────────────────

vec2 repXZ(vec2 p, float s)
{
    return mod(p + s * 0.5, s) - s * 0.5;
}

float rep1(float p, float s)
{
    return mod(p + s * 0.5, s) - s * 0.5;
}

// ── Staircase: analytical SDF, no inner loop ──────────────────────────────────

float sdStairField(vec3 p, float stepH, float stepD)
{
    float i = floor(p.y / stepH);
    float best = 1e9;

    for (int k = -1; k <= 1; k++)
    {
        float fi     = i + float(k);
        float treadY = fi * stepH;
        float treadX = fi * stepD;

        vec3 riserP  = p - vec3(treadX, treadY + stepH * 0.5, 0.0);
        float riser  = sdBox(riserP, vec3(stepD * 0.08, stepH * 0.5, 1.8));

        vec3 treadP  = p - vec3(treadX + stepD * 0.5, treadY, 0.0);
        float tread  = sdBox(treadP, vec3(stepD * 0.5, stepH * 0.08, 1.8));

        best = min(best, min(riser, tread));
    }

    return best;
}

// ── Scene ─────────────────────────────────────────────────────────────────────
//
// Materials:
//   1 – floor slabs        4 – ceiling vaults
//   2 – monoliths/debris   5 – pipes/cables
//   3 – staircases         6 – shaft glow pillars

HitInfo minH(HitInfo a, HitInfo b)
{
    return (a.dist < b.dist) ? a : b;
}

HitInfo map(vec3 p)
{
    HitInfo res;
    res.dist     = 1e10;
    res.material = 0;

    float fy    = rep1(p.y + 0.6, 22.0);
    float slabD = abs(fy) - 1.2;
    res = minH(res, HitInfo(slabD, 1));

    vec2  qxz = repXZ(p.xz, 28.0);
    vec2  cell  = floor((p.xz + 14.0) / 28.0);
    float mh    = 40.0 + dot(fract(cell * vec2(0.317, 0.123)), vec2(12.0, 10.0));
    float monoD = sdBox(vec3(qxz.x, p.y - mh * 0.5 + 5.0, qxz.y),
                        vec3(3.2, mh, 3.2));
    res = minH(res, HitInfo(monoD, 2));

    vec2  q2xz  = repXZ(p.xz + vec2(14.0), 28.0);
    vec2  cell2 = floor(p.xz / 28.0);
    float mh2   = 28.0 + dot(fract(cell2 * vec2(0.211, 0.347)), vec2(10.0, 8.0));
    float mono2D = sdBox(vec3(q2xz.x, p.y - mh2 * 0.5, q2xz.y),
                         vec3(1.8, mh2, 1.8));
    res = minH(res, HitInfo(mono2D, 2));

    vec2  cvxz  = repXZ(p.xz, 56.0);
    float vaultD = sdBox(vec3(cvxz.x, p.y - 38.0, cvxz.y),
                         vec3(22.0, 2.5, 22.0));
    res = minH(res, HitInfo(vaultD, 4));

    vec2  stxz = repXZ(p.xz + vec2(6.0), 28.0);
    vec3  st   = vec3(stxz.x - 5.0, p.y - 2.0, stxz.y);
    float stD  = sdStairField(st, 1.1, 1.0);
    res = minH(res, HitInfo(stD, 3));

    vec3  st2  = vec3(stxz.y - 5.0, p.y - 8.0, stxz.x);
    float stD2 = sdStairField(st2, 1.1, 1.0);
    res = minH(res, HitInfo(stD2, 3));

    vec2  shxz  = repXZ(p.xz + vec2(14.0), 56.0);
    float glowD = sdCylinder(vec3(shxz.x, p.y, shxz.y), 0.22, 9000.0);
    res = minH(res, HitInfo(glowD, 6));

    vec2  cbxz = repXZ(p.xz + vec2(6.0), 14.0);
    float cD0  = sdCylinder(vec3(cbxz.x - 0.22, p.y, cbxz.y), 0.06, 9000.0);
    float cD1  = sdCylinder(vec3(cbxz.x + 0.22, p.y, cbxz.y), 0.06, 9000.0);
    res = minH(res, HitInfo(min(cD0, cD1), 5));

    vec2  dbxz  = repXZ(p.xz + vec2(7.0), 18.0);
    float dbPh  = floor(p.y / 22.0);
    float dbOx  = fract(dbPh * 0.317) * 6.0 - 3.0;
    float dbOz  = fract(dbPh * 0.123) * 6.0 - 3.0;
    float debD  = sdBox(vec3(dbxz.x - dbOx,
                             mod(p.y + 11.0, 22.0) - 2.0,
                             dbxz.y - dbOz),
                        vec3(0.6, 0.4, 0.8));
    res = minH(res, HitInfo(debD, 2));

    return res;
}

// ── Normal ────────────────────────────────────────────────────────────────────

vec3 calcNormal(vec3 p)
{
    const float e = 0.002;
    return normalize(vec3(
        map(p + vec3(e, 0, 0)).dist - map(p - vec3(e, 0, 0)).dist,
        map(p + vec3(0, e, 0)).dist - map(p - vec3(0, e, 0)).dist,
        map(p + vec3(0, 0, e)).dist - map(p - vec3(0, 0, e)).dist
    ));
}

// ── Soft shadow ───────────────────────────────────────────────────────────────

float softShadow(vec3 ro, vec3 rd)
{
    float res = 1.0;
    float t   = 0.1;
    for (int i = 0; i < 16; i++)
    {
        float h = map(ro + rd * t).dist;
        res = min(res, 6.0 * h / t);
        t  += clamp(h, 0.05, 0.8);
        if (h < 0.001 || t > 50.0) break;
    }
    return clamp(res, 0.0, 1.0);
}

// ── Ambient occlusion ─────────────────────────────────────────────────────────

float ambientOcclusion(vec3 p, vec3 n)
{
    float ao     = 0.0;
    float weight = 1.0;
    for (int i = 1; i <= 4; i++)
    {
        float d        = 0.18 * float(i);
        float sampleDist = map(p + n * d).dist;
        ao     += (d - sampleDist) * weight;
        weight *= 0.5;
    }
    return clamp(1.0 - ao, 0.0, 1.0);
}

// ── Raymarcher ────────────────────────────────────────────────────────────────

float raymarch(vec3 ro, vec3 rd, out int material)
{
    float t  = 0.0;
    material = 0;
    for (int i = 0; i < 128; i++)
    {
        vec3    p = ro + rd * t;
        HitInfo h = map(p);
        if (h.dist < 0.002)
        {
            material = h.material;
            return t;
        }
        t += h.dist;
        if (t > 300.0) break;
    }
    return -1.0;
}

// ── Hash / noise helpers ──────────────────────────────────────────────────────

// Cheap 2D hash → [0,1)
float hash21(vec2 p)
{
    p = fract(p * vec2(127.1, 311.7));
    p += dot(p, p + 19.19);
    return fract(p.x * p.y);
}

// Value noise (2D), 4-tap bilinear
float vnoise2(vec2 p)
{
    vec2 i = floor(p);
    vec2 f = fract(p);
    vec2 u = f * f * (3.0 - 2.0 * f);
    float a = hash21(i);
    float b = hash21(i + vec2(1, 0));
    float c = hash21(i + vec2(0, 1));
    float d = hash21(i + vec2(1, 1));
    return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
}

// Two-octave fBm
float fbm2(vec2 p)
{
    return vnoise2(p) * 0.6 + vnoise2(p * 2.7 + 5.3) * 0.3
         + vnoise2(p * 7.1 + 2.1) * 0.1;
}

// ── Main ──────────────────────────────────────────────────────────────────────

void main()
{
    ivec2 pos     = ivec2(gl_GlobalInvocationID.xy);
    ivec2 imgSize = imageSize(destImage);

    if (pos.x >= imgSize.x || pos.y >= imgSize.y)
        return;

    vec2 uv = (vec2(pos) + 0.5) / vec2(imgSize);
    uv = uv * 2.0 - 1.0;
    uv.x *= float(imgSize.x) / float(imgSize.y);
    uv.y *= -1.0;

    vec3 ro      = vec3(5.0, 6.5, 2.0);
    vec3 target  = vec3(-3.0, 10.0, 40.0);
    vec3 forward = normalize(target - ro);
    vec3 right   = normalize(cross(forward, vec3(0, 1, 0)));
    vec3 up      = cross(right, forward);
    vec3 rd      = normalize(forward + uv.x * right + uv.y * up);

    int   material;
    float t = raymarch(ro, rd, material);

    vec3 color;

    if (t > 0.0)
    {
        vec3 p = ro + rd * t;
        vec3 n = calcNormal(p);

        vec3  L1   = normalize(vec3(-1.0,  2.0, -0.5));
        vec3  L2   = normalize(vec3( 0.5, -1.0,  0.3));
        float sh   = softShadow(p + n * 0.02, L1);
        float diff = max(dot(n, L1), 0.0) * sh;
        float fill = max(dot(n, L2), 0.0) * 0.08;
        float occ  = ambientOcclusion(p, n);

        vec3 base;

        if (material == 1)
        {
            // ── Polished dark basalt floor with cyan-tinged grout lines ──────
            // Tile grid with sharp grout channels
            vec2  tile = fract(p.xz * 0.25);
            float grout = 1.0 - smoothstep(0.03, 0.06, min(tile.x, tile.y))
                              * smoothstep(0.03, 0.06, min(1.0 - tile.x, 1.0 - tile.y));
            // Subtle surface noise per tile (variation in stone slab "grain")
            float grain  = fbm2(p.xz * 1.4 + floor(p.xz * 0.25) * 31.7);
            vec3  stone  = mix(vec3(0.04, 0.045, 0.06),
                               vec3(0.10, 0.11,  0.14), grain * 0.5);
            // Glowing grout: dim teal emission bled into gap
            vec3  groutC = mix(stone, vec3(0.02, 0.18, 0.22), grout * 0.45);
            // Slight reflection tint — fresnel-ish: surfaces facing up get more blue
            float fUp    = pow(max(dot(n, vec3(0, 1, 0)), 0.0), 2.0);
            base = mix(groutC, vec3(0.05, 0.12, 0.20), fUp * 0.12);
        }
        else if (material == 2)
        {
            // ── Brutalist concrete with rust streaks and lichen patches ───────
            float macro = fbm2(p.xz * 0.18 + p.y * 0.07);  // large-scale staining
            float micro = vnoise2(p.xz * 3.1 + p.y * 2.3); // fine surface texture

            // Rust stain: runs down from corners/edges, driven by fbm
            float rustMask = smoothstep(0.48, 0.72, fbm2(p.xz * 0.6 + p.y * 0.2 + 3.7));
            vec3  rust     = mix(vec3(0.28, 0.14, 0.05), vec3(0.45, 0.20, 0.04), micro);

            // Lichen: blue-green crust in sheltered patches (low y variation)
            float lichenMask = smoothstep(0.55, 0.75, fbm2(p.xz * 0.9 + 7.3))
                             * smoothstep(-0.3, 0.1, -abs(dot(n, vec3(0, 1, 0))) + 0.4);
            vec3  lichen     = mix(vec3(0.08, 0.15, 0.10), vec3(0.12, 0.22, 0.14),
                                   vnoise2(p.xz * 5.0));

            // Base concrete colour, varied by macro noise
            vec3  conc = mix(vec3(0.07, 0.075, 0.09),
                             vec3(0.16, 0.165, 0.20), macro * 0.55);
            conc = mix(conc, rust,   rustMask   * 0.7);
            conc = mix(conc, lichen, lichenMask * 0.6);

            base = conc + micro * 0.012;
        }
        else if (material == 3)
        {
            // ── Stone stairs: worn edge highlight + bioluminescent crack seams ─
            // Detect step edges: high curvature zones (normal tilted near 45°)
            float edgeGlow = 1.0 - abs(dot(n, vec3(0, 1, 0)))
                                 - abs(dot(n, vec3(1, 0, 0)));
            edgeGlow = clamp(edgeGlow * 4.0, 0.0, 1.0);

            // Crack network in the tread surface via layered noise
            float crack  = smoothstep(0.62, 0.65,
                              fbm2(p.xz * 4.0 + p.y * 0.8));
            // Glow seeping out of cracks: dim violet
            vec3  crackC = vec3(0.18, 0.04, 0.35) * crack * 1.8;

            // Worn stone albedo — slightly warmer than concrete
            float wear  = fbm2(p.xz * 2.2 + p.y * 1.0);
            vec3  stone = mix(vec3(0.10, 0.095, 0.115),
                              vec3(0.20, 0.19,  0.22), wear * 0.4);
            // Polished tread centres catch more light
            stone += edgeGlow * vec3(0.06, 0.06, 0.08);

            base = stone + crackC;
        }
        else if (material == 4)
        {
            // ── Vaulted ceiling: soot-darkened with amber ember spots ─────────
            float soot  = fbm2(p.xz * 0.25 + 1.3);
            float ember = smoothstep(0.70, 0.74,
                              fbm2(p.xz * 1.8 + p.y * 0.3 + 9.1));

            vec3  ceilC = mix(vec3(0.02, 0.018, 0.022),
                              vec3(0.06, 0.055, 0.065), soot * 0.6);
            // Warm amber ember embers: old scorch marks that still faintly glow
            ceilC = mix(ceilC, vec3(0.50, 0.22, 0.03), ember * 0.28);

            // Thin crystalline deposit veins across the vault surface
            float vein  = smoothstep(0.60, 0.62, vnoise2(p.xz * 6.0 + p.y));
            ceilC = mix(ceilC, vec3(0.30, 0.35, 0.45), vein * 0.18);

            base = ceilC;
        }
        else if (material == 5)
        {
            // ── Corroded metal pipes: tarnished copper/iron with verdigris ────
            // Axial corrosion stripe pattern
            float axial  = fract(p.y * 0.8);
            float stripe = smoothstep(0.45, 0.55, axial) * smoothstep(0.55, 0.45, axial);

            // Verdigris (oxidised copper green) blotches
            float verdMask = smoothstep(0.52, 0.68,
                                fbm2(vec2(p.y * 1.3, atan(p.x, p.z) * 2.0 + 4.0)));
            vec3  verd  = mix(vec3(0.12, 0.28, 0.22), vec3(0.08, 0.38, 0.30),
                              vnoise2(vec2(p.y * 2.0, 0.0)));

            // Base tarnished metal — dark bronze/iron
            vec3  metal = mix(vec3(0.18, 0.12, 0.08),
                              vec3(0.30, 0.22, 0.14), stripe * 0.4);
            metal = mix(metal, verd, verdMask * 0.65);

            base = metal;
        }
        else
        {
            // ── Shaft glow pillars: plasma column with iridescent shell ───────
            // Smooth vertical plasma bands
            float plasma = sin(p.y * 0.4) * 0.5 + 0.5;
            plasma += sin(p.y * 1.1 + 1.5) * 0.25;
            plasma  = clamp(plasma, 0.0, 1.0);

            // Iridescent shell tint — varies with viewing angle (fresnel proxy)
            float fres  = pow(1.0 - abs(dot(n, -rd)), 3.0);
            vec3  iriA  = vec3(0.05, 0.50, 0.90);   // cool blue core
            vec3  iriB  = vec3(0.60, 0.10, 0.80);   // violet shell
            vec3  iriC  = vec3(0.10, 0.80, 0.55);   // teal rim
            vec3  iriCol = mix(mix(iriA, iriB, fres), iriC, fres * fres);

            base = iriCol * (0.8 + plasma * 0.5);
        }

        // ── Common shading ────────────────────────────────────────────────────

        // Specular: roughness differs per material
        float roughness;
        if      (material == 1) roughness = 12.0;   // polished floor
        else if (material == 5) roughness = 48.0;   // corroded pipe (lower gloss)
        else if (material == 6) roughness = 128.0;  // glassy plasma pillar
        else                    roughness = 20.0;   // everything else (stone/concrete)

        float specStr;
        if      (material == 1) specStr = 0.18;
        else if (material == 5) specStr = 0.12;
        else if (material == 6) specStr = 0.60;
        else                    specStr = 0.05;

        vec3  hv   = normalize(L1 - rd);
        float spec = pow(max(dot(n, hv), 0.0), roughness);
        vec3  specTint = (material == 5) ? vec3(0.9, 0.7, 0.5)   // warm for copper
                       : (material == 1) ? vec3(0.6, 0.8, 1.0)   // cool for stone
                       :                   vec3(0.7, 0.8, 1.0);

        color = base * (0.08 + diff + fill) * occ;
        color += spec * specStr * specTint;

        // Per-material emissive contributions
        if (material == 6)
        {
            // Pulsing plasma: intensity modulated by plasma value built into base
            float plasma2 = sin(p.y * 0.4) * 0.5 + 0.5;
            color += base * (0.6 + plasma2 * 0.8);
        }

        // Rim light on monoliths (mat 2) — sharper, deeper blue
        if (material == 2)
        {
            float rim = 1.0 - max(dot(n, -rd), 0.0);
            color += pow(rim, 3.0) * vec3(0.01, 0.03, 0.14) * 0.7;
        }

        // Grout line and crack emissive bleed for floor/stairs
        if (material == 1)
        {
            vec2  tile  = fract(p.xz * 0.25);
            float grout = 1.0 - smoothstep(0.03, 0.06, min(tile.x, tile.y))
                              * smoothstep(0.03, 0.06, min(1.0 - tile.x, 1.0 - tile.y));
            color += vec3(0.01, 0.20, 0.28) * grout * 0.18;
        }

        // Subtle amber self-emission from ember spots in ceiling
        if (material == 4)
        {
            float ember = smoothstep(0.70, 0.74,
                              fbm2(p.xz * 1.8 + p.y * 0.3 + 9.1));
            color += vec3(0.80, 0.30, 0.02) * ember * 0.20;
        }

        // Fog
        float fog1 = exp(-t * 0.018);
        float fog2 = exp(-t * 0.006);
        color = mix(vec3(0.01, 0.015, 0.03),
                    mix(vec3(0.02, 0.03, 0.06), color, fog2), fog1);
    }
    else
    {
        float yg = max(rd.y * 0.5 + 0.5, 0.0);
        color = mix(vec3(0.005, 0.008, 0.018),
                    vec3(0.015, 0.025, 0.060), yg * yg);
    }

    color = color / (1.0 + color);
    color = pow(color, vec3(0.4545));

    vec2  vt   = (vec2(pos) + 0.5) / vec2(imgSize) * 2.0 - 1.0;
    color *= clamp(1.0 - dot(vt, vt) * 0.35, 0.0, 1.0);

    imageStore(destImage, pos, vec4(color, 1.0));
}
