#version 450
#extension GL_GOOGLE_include_directive : require

layout(local_size_x = 16, local_size_y = 16) in;
layout(set = 1, binding = 0, rgba8) uniform writeonly image2D destImage;

struct HitInfo
{
    float dist;
    int material;
};

float sdSphere(vec3 p, float r)
{
    return length(p) - r;
}

float sdBox(vec3 p, vec3 b)
{
    vec3 q = abs(p) - b;
    return length(max(q,0.0)) + min(max(q.x,max(q.y,q.z)),0.0);
}

vec2 repeatXZ(vec2 p, float size)
{
    return mod(p + size * 0.5, size) - size * 0.5;
}

HitInfo map(vec3 p)
{
    HitInfo result;
    result.dist = 1e10;
    result.material = 0;

    // Wavy floor
    float floorHeight =
        -2.0 +
        sin(p.x * 0.15) * 1.5 +
        cos(p.z * 0.15) * 1.5;

    float floorD = p.y - floorHeight;

    if(floorD < result.dist)
    {
        result.dist = floorD;
        result.material = 1;
    }

    // Infinite pillars
    vec3 q = p;
    q.xz = repeatXZ(q.xz, 8.0);

    float pillar = sdBox(
        q - vec3(0.0, 2.0, 0.0),
        vec3(0.6, 4.0, 0.6));

    if(pillar < result.dist)
    {
        result.dist = pillar;
        result.material = 2;
    }

    // Floating spheres
    vec3 s = p;
    s.xz = repeatXZ(s.xz + vec2(4.0), 12.0);

    float glowSphere = sdSphere(
        s - vec3(0.0, 3.0, 0.0),
        0.8);

    if(glowSphere < result.dist)
    {
        result.dist = glowSphere;
        result.material = 3;
    }

    return result;
}

vec3 calcNormal(vec3 p)
{
    const float e = 0.001;

    return normalize(vec3(
        map(p + vec3(e,0,0)).dist - map(p - vec3(e,0,0)).dist,
        map(p + vec3(0,e,0)).dist - map(p - vec3(0,e,0)).dist,
        map(p + vec3(0,0,e)).dist - map(p - vec3(0,0,e)).dist
    ));
}

float softShadow(vec3 ro, vec3 rd)
{
    float res = 1.0;
    float t = 0.05;

    for(int i = 0; i < 32; i++)
    {
        float h = map(ro + rd * t).dist;

        res = min(res, 8.0 * h / t);

        t += clamp(h, 0.02, 0.5);

        if(h < 0.001)
            return 0.0;

        if(t > 50.0)
            break;
    }

    return clamp(res, 0.0, 1.0);
}

float ambientOcclusion(vec3 p, vec3 n)
{
    float ao = 0.0;
    float weight = 1.0;

    for(int i = 1; i <= 5; i++)
    {
        float d = 0.15 * float(i);
        float sampleDist = map(p + n * d).dist;

        ao += (d - sampleDist) * weight;
        weight *= 0.6;
    }

    return clamp(1.0 - ao, 0.0, 1.0);
}

float raymarch(vec3 ro, vec3 rd, out int material)
{
    float t = 0.0;
    material = 0;

    for(int i = 0; i < 1024; i++)
    {
        vec3 p = ro + rd * t;

        HitInfo h = map(p);

        if(h.dist < 0.001)
        {
            material = h.material;
            return t;
        }

        t += h.dist;

        if(t > 1024.0)
            break;
    }

    return -1.0;
}

void main()
{
    ivec2 pos = ivec2(gl_GlobalInvocationID.xy);
    ivec2 imgSize = imageSize(destImage);

    if(pos.x >= imgSize.x || pos.y >= imgSize.y)
        return;

    vec2 uv = (vec2(pos) + 0.5) / vec2(imgSize);
    uv = uv * 2.0 - 1.0;
    uv.x *= float(imgSize.x) / float(imgSize.y);
    uv.y *= -1;
    // Camera
    vec3 ro = vec3(2.0, 2.0, -8.0);

    vec3 target = vec3(0.0, 1.5, 5.0);

    vec3 forward = normalize(target - ro);
    vec3 right = normalize(cross(forward, vec3(0,1,0)));
    vec3 up = cross(right, forward);

    vec3 rd = normalize(
        forward +
        uv.x * right +
        uv.y * up
    );

    int material;
    float t = raymarch(ro, rd, material);

    vec3 color;

    if(t > 0.0)
    {
        vec3 p = ro + rd * t;
        vec3 n = calcNormal(p);

        vec3 lightPos = vec3(-20.0, 25.0, -10.0);
        vec3 lightDir = normalize(lightPos - p);

        float shadow =
            softShadow(
                p + n * 0.01,
                lightDir);

        float diff =
            max(dot(n, lightDir), 0.0) *
            shadow;

        float ao = ambientOcclusion(p, n);

        vec3 base;

        if(material == 1)
        {
            float checker =
                mod(floor(p.x) + floor(p.z), 2.0);

            base = mix(
                vec3(0.08),
                vec3(0.12, 0.1, 0.2),
                checker);
        }
        else if(material == 2)
        {
            base = vec3(0.3, 0.35, 0.4);
        }
        else
        {
            base = vec3(0.1, 0.4, 1.0);
        }

        color = base * (0.15 + diff) * ao;

        if(material == 3)
        {
            color += vec3(1.0, 0.2, 0.2);
        }

        vec3 h =
            normalize(lightDir - rd);

        float spec =
            pow(max(dot(n,h),0.0),64.0);

        color += spec;

        float fog =
            exp(-t * 0.025);

        color = mix(
            vec3(0.02,0.03,0.05),
            color,
            fog);
    }
    else
    {
        float sky =
            max(rd.y * 0.5 + 0.5, 0.0);

        color = mix(
            vec3(0.01,0.02,0.04),
            vec3(0.1,0.2,0.5),
            sky);

        color += pow(max(rd.y,0.0),16.0) * 0.2;
    }

    // Mild tonemap
    color = color / (1.0 + color);

    // Gamma
    color = pow(color, vec3(0.4545));

    imageStore(destImage, pos, vec4(color, 1.0));
}